# Vercel / 本地：须使用 PostgreSQL（SQLite 不再用于服务端部署）
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# JWT 登录会话签名密钥（至少 32 位随机字符串；切勿泄露或提交到仓库）
AUTH_SECRET=""

# 浏览器访问站点根 URL（用于邮件文案；生产填 https://你的域名）
APP_ORIGIN="http://localhost:3000"

# 可选：SMTP 发信（找回密码验证码）。不配则在开发环境把验证码打到服务端日志。
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="0"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# 可选：定时任务 /api/cron/* 请求头 Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""
