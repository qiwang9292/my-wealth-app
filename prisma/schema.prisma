// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  products           Product[]
  categoryTargets    CategoryTarget[]
  snapshots          Snapshot[]
  passwordResetCodes PasswordResetCode[]
}

model PasswordResetCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Product {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  code         String?
  type         String    @default("OTHER")
  category     String    @default("权益")
  subCategory  String?
  account      String?
  riskLevel    String?
  dividendMethod String?
  maturityDate DateTime?
  costOverride Decimal?
  unitsOverride Decimal?
  dcaEnabled     Boolean   @default(false)
  dcaAmount      Decimal?
  dcaFrequency   String?
  dcaDayOfMonth  Int?
  dcaWeekday     Int?
  dcaAnchorDate  DateTime?
  dcaMaterializedThroughYmd String?
  closedAt     DateTime?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  transactions   Transaction[]
  dailyPrices    DailyPrice[]
  snapshotItems  SnapshotItem[]

  @@index([userId])
  @@index([userId, deletedAt, closedAt])
}

model CategoryTarget {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category            String
  targetAllocationPct Decimal
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, category])
}

model Transaction {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String
  date      DateTime
  quantity  Decimal  @default(0)
  price     Decimal?
  amount    Decimal
  note      String?  @default("")
  createdAt DateTime @default(now())

  @@index([productId, date])
}

model DailyPrice {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  date      DateTime
  price     Decimal
  createdAt DateTime @default(now())

  @@unique([productId, date])
  @@index([productId])
}

model Snapshot {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshotDate DateTime
  createdAt    DateTime @default(now())
  note         String?  @default("")

  items SnapshotItem[]

  @@index([userId])
  @@index([userId, snapshotDate])
}

model SnapshotItem {
  id            String   @id @default(cuid())
  snapshotId    String
  snapshot      Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  units         Decimal
  unitPrice     Decimal
  totalValue    Decimal
  allocationPct Decimal?
  costBasis     Decimal?

  @@unique([snapshotId, productId])
  @@index([snapshotId])
}
